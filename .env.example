# Copy to `.env` and fill in. NEVER commit your `.env`.

# === LLM providers (cascade: any one is enough; more = better fallback) ===
# Groq:        https://console.groq.com/keys
# Gemini:      https://aistudio.google.com/apikey
# OpenRouter:  https://openrouter.ai/keys
# Cloudflare:  https://dash.cloudflare.com/profile/api-tokens
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Self-hosted Ollama (OpenAI-compatible). Leave empty to skip.
OLLAMA_BASE_URL=
OLLAMA_MODEL=nemotron-3-nano:4b

# === Data providers ===
# Groww live data + MCP — OPTIONAL. The Groww API is IP-whitelisted (your
# server's egress IP must be registered in the Groww developer portal), so
# most personal/laptop deployments cannot use it. Leave these empty and the
# agent falls back transparently to yfinance for OHLCV, live quotes, and
# fundamentals — no further config needed.
GROWW_API_KEY=
GROWW_TOTP_SECRET=
GROWW_ACCESS_TOKEN=

# === Runtime ===
# Optional override for which paper portfolio is "default" (see config.py).
# DEFAULT_PORTFOLIO=main
